generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum TipoPessoa {
  PF
  PJ
}

enum TipoCertificado {
  A1
  A3
}

enum SuporteCertificado {
  TOKEN
  CARTAO
  NUVEM
  ARQUIVO
  SEM_MIDIA
}

enum StatusCertificado {
  ATIVO
  VENCIDO
  CANCELADO
  RENOVADO
  NAO_RENOVADO
  REVOGADO
}

enum StatusRenovacaoManual {
  PROSPECT
  CONVERTIDA
  DESCARTADA
}

enum OrigemRenovacaoManual {
  MANUAL
  IMPORTADO
  CERTIFICADO
}

enum StatusPedido {
  GERADO
  VERIFICADO
  EMITIDO
  CANCELADO
}

enum TipoLancamento {
  RECEBER
  PAGAR
}

enum StatusLancamento {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum Role {
  ADMIN
  GERENTE
  OPERADOR
  FINANCEIRO
  VISUALIZADOR
  // Agente de Registro (mesmo acesso do OPERADOR) + leitura/baixa de Contas a
  // Receber — criado 14/07/2026 a pedido do Vinicius pra Laryssa, que ajuda
  // nas cobranças. Contas a Pagar continua exclusivo de ADMIN/GERENTE.
  OPERADOR_FINANCEIRO
}

enum StatusEmail {
  PENDENTE
  ENVIADO
  ERRO
}

enum TipoEmailAutomatico {
  VENCIMENTO_60
  VENCIMENTO_30
  VENCIMENTO_15
  VENCIMENTO_7
  VENCIDO_1
  VENCIDO_7
  POS_EMISSAO
  NUTRICAO_3M
  NUTRICAO_6M
  NUTRICAO_9M
  COBRANCA_FINANCEIRA
  CAMPANHA_MARKETING
}

// ─── USUÁRIOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id         String   @id @default(cuid())
  nome       String
  username   String?  @unique
  email      String?  @unique
  senha      String
  role       Role     @default(OPERADOR)
  ativo      Boolean  @default(true)
  avatar     String?
  whatsapp   String?
  nomeAgrDs  String?
  unidade    String?
  comissao   Decimal? @db.Decimal(5, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessoes              Sessao[]
  auditoria            AuditLog[]
  pedidos              Pedido[]
  historicoContatos    HistoricoContato[]
  parceirosResponsavel Parceiro[]          @relation("ParceiroResponsavel")
  orcamentos           Orcamento[]
  sessaoAtividade      SessaoAtividade[]

  certificadosNaoRenovadosPor Certificado[]     @relation("CertificadoNaoRenovadoPor")
  certificadosRevogadosPor    Certificado[]     @relation("CertificadoRevogadoPor")
  renovacoesManuaisCriadas    RenovacaoManual[] @relation("RenovacaoManualCriadoPor")
  renovacoesManuaisResponsavel RenovacaoManual[] @relation("RenovacaoManualResponsavel")

  ocorrenciasResponsavel  OcorrenciaQualidade[] @relation("OcorrenciaResponsavel")
  ocorrenciasRegistradas  OcorrenciaQualidade[] @relation("OcorrenciaRegistradoPor")
  focosDoDia              FocoDoDia[]
  melhoriasContinuas      MelhoriaContinua[]

  @@map("usuarios")
}

model Sessao {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sessoes")
}

// ─── CLIENTES ─────────────────────────────────────────────────────────────────

model Cliente {
  id             String     @id @default(cuid())
  tipoPessoa     TipoPessoa
  nome           String
  email          String?
  telefone       String?
  celular        String?
  cpf            String?    @unique
  cnpj           String?    @unique
  rg             String?
  dataNascimento DateTime?
  razaoSocial    String?
  nomeFantasia   String?
  responsavel    String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  observacoes    String?
  grupo          String?
  pisNis         String?
  ddd            String?
  ativo          Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  parceiro   Parceiro? @relation(fields: [parceiroId], references: [id])
  parceiroId String?

  // PJ → PF: quando um PJ é criado junto com seu responsável PF, gravamos o vínculo aqui
  responsavelCliente   Cliente?  @relation("PJResponsavel", fields: [responsavelClienteId], references: [id])
  responsavelClienteId String?
  // PF → PJs: lista de empresas das quais este PF é responsável
  empresasResponsavel  Cliente[] @relation("PJResponsavel")

  certificados      Certificado[]
  pedidos           Pedido[]
  emails            EmailLog[]
  historicoContatos HistoricoContato[]
  renovacoesManuais RenovacaoManual[]

  @@map("clientes")
}

// ─── HISTÓRICO DE CONTATOS ────────────────────────────────────────────────────

model HistoricoContato {
  id             String    @id @default(cuid())
  clienteId      String
  certificadoId  String?
  observacao     String    @db.Text
  dataContato    DateTime  @default(now())
  proximoContato DateTime?
  usuarioId      String?
  createdAt      DateTime  @default(now())

  cliente     Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  certificado Certificado? @relation(fields: [certificadoId], references: [id])
  usuario     Usuario?     @relation(fields: [usuarioId], references: [id])

  @@map("historico_contatos")
}

// ─── PARCEIROS INDICADORES ────────────────────────────────────────────────────

model Parceiro {
  id          String     @id @default(cuid())
  tipoPessoa  TipoPessoa
  nome        String
  email       String?
  telefone    String?
  celular     String?
  cpf         String?    @unique
  cnpj        String?    @unique
  razaoSocial String?
  tipo        String
  banco       String?
  agencia     String?
  conta       String?
  tipoConta   String?
  chavePix    String?
  observacoes          String?
  ativo                Boolean    @default(true)
  // Campos extras
  nomeFantasia         String?
  nivel                String?
  tipoParceria         String?
  segmento             String?   // ramo de atuação do parceiro (Contabilidade, Correspondente, etc.)
  renovacoes           String?
  responsavelId        String?
  contadorResponsavel  String?
  pessoaContato        String?
  emailAlternativo     String?
  telefone2            String?
  informacoesEnvio     String?    @db.Text
  tipoComissao         String?
  diaPagamento         Int?
  loginParceiro        String?    @unique
  senhaParceiro        String?
  statusPainel             Boolean    @default(false)
  permissoesPainel         Json?
  whatsappVencimentoAtivo  Boolean    @default(true)
  emailVencimentoAtivo     Boolean    @default(true)
  // Tabela de preço de custo vinculada (26/06/2026) — quando preenchida, o
  // "Valor de Custo" de cada modelo passa a vir da tabela (ao vivo: se a
  // tabela mudar depois, reflete automaticamente), em vez de precisar
  // cadastrar modelo por modelo. Modelos que não estão na tabela continuam
  // editáveis manualmente em Comissao.valorCusto (ver tabela-preco.lib.ts).
  tabelaPrecoId        String?
  dataNascimento           DateTime?  // para envio automático de parabéns no aniversário
  ultimoAniversarioEnviado Int?       // ano (ex: 2026) do último envio de parabéns, para dedup
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  responsavel      Usuario?          @relation("ParceiroResponsavel", fields: [responsavelId], references: [id])
  tabelaPreco      TabelaPreco?      @relation(fields: [tabelaPrecoId], references: [id])
  clientes         Cliente[]
  comissoes        Comissao[]
  pedidos          Pedido[]
  lancamentos      Lancamento[]
  contatosParceiro ContatoParceiro[]
  comissoesPedido  ComissaoPedido[]

  @@map("parceiros")
}

// ─── TABELAS DE PREÇO DE CUSTO ─────────────────────────────────────────────────
// Cada tabela tem um valor de custo por modelo de certificado (ex.: "Tabela 1"
// a "Tabela 5", da VEG Certificadora, 29/06/2026). Um parceiro pode ser
// vinculado a uma tabela inteira em vez de preencher modelo por modelo — e,
// por decisão do Vinicius, o vínculo é "ao vivo": editar a tabela depois
// atualiza todos os parceiros vinculados a ela automaticamente.

model TabelaPreco {
  id        String            @id @default(cuid())
  nome      String            @unique
  itens     TabelaPrecoItem[]
  parceiros Parceiro[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("tabelas_preco")
}

model TabelaPrecoItem {
  id            String   @id @default(cuid())
  tabelaPrecoId String
  modeloId      String
  valorCusto    Decimal  @db.Decimal(10, 2)

  tabelaPreco TabelaPreco       @relation(fields: [tabelaPrecoId], references: [id], onDelete: Cascade)
  modelo      ModeloCertificado @relation(fields: [modeloId], references: [id])

  @@unique([tabelaPrecoId, modeloId])
  @@map("tabela_preco_itens")
}

model ContatoParceiro {
  id             String    @id @default(cuid())
  parceiroId     String
  nome           String
  cpf            String?
  cargo          String?
  dataNascimento DateTime?
  telefone       String?
  email          String?
  createdAt      DateTime  @default(now())

  parceiro Parceiro @relation(fields: [parceiroId], references: [id], onDelete: Cascade)

  @@map("contatos_parceiro")
}

model Comissao {
  id         String   @id @default(cuid())
  parceiroId String
  modeloId   String
  percentual   Decimal?  @db.Decimal(5, 2)
  valorFixo    Decimal?  @db.Decimal(10, 2)
  valorCusto   Decimal?  @db.Decimal(10, 2)
  valorCliente Decimal?  @db.Decimal(10, 2)
  ativo        Boolean   @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parceiro Parceiro          @relation(fields: [parceiroId], references: [id])
  modelo   ModeloCertificado @relation(fields: [modeloId], references: [id])

  @@unique([parceiroId, modeloId])
  @@map("comissoes")
}

// Comissão por pedido individual (29/06/2026 — substitui o fechamento
// mensal único, que nunca chegou a ser usado com dados reais). Cada
// certificado emitido com parceiro gera uma linha aqui; o pagamento é
// feito selecionando quais linhas entram em cada lote — clientes que
// ainda não pagaram a V&G ficam "PENDENTE" indefinidamente (sem prazo),
// reaparecendo em qualquer mês seguinte até serem marcados como pagos.
model ComissaoPedido {
  id            String    @id @default(cuid())
  pedidoId      String    @unique
  parceiroId    String
  valorCusto    Decimal   @db.Decimal(10, 2)
  valorCliente  Decimal   @db.Decimal(10, 2)
  valorComissao Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDENTE") // PENDENTE | PAGO
  lancamentoId  String?
  pagoEm        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pedido     Pedido      @relation(fields: [pedidoId], references: [id])
  parceiro   Parceiro    @relation(fields: [parceiroId], references: [id])
  lancamento Lancamento? @relation(fields: [lancamentoId], references: [id])

  @@map("comissoes_pedido")
}

// ─── MODELOS DE CERTIFICADO ───────────────────────────────────────────────────

model ModeloCertificado {
  id              String             @id @default(cuid())
  nome            String
  descricao       String?
  tipoPessoa      TipoPessoa
  tipoCertificado TipoCertificado
  suporte         SuporteCertificado
  validadeMeses   Int                @default(12)
  preco           Decimal            @db.Decimal(10, 2)
  codigoSafeweb   String?
  ativo           Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  certificados Certificado[]
  comissoes    Comissao[]
  itensPedido  ItemPedido[]
  tabelaPrecoItens TabelaPrecoItem[]

  @@map("modelos_certificado")
}

// ─── CERTIFICADOS ─────────────────────────────────────────────────────────────

model Certificado {
  id             String            @id @default(cuid())
  clienteId      String
  modeloId       String
  pedidoId       String?
  numeroSerie    String?
  dataEmissao    DateTime?
  dataVencimento DateTime?
  status         StatusCertificado @default(ATIVO)
  safewebId      String?
  observacoes    String?
  // Valor para certificados cadastrados manualmente (sem Pedido vinculado —
  // ex.: emitido em outro lugar, só anotado aqui para lembrete de vencimento).
  // Quando há Pedido, o valor exibido vem de Pedido.valorFinal, não daqui.
  valorManual    Decimal?          @db.Decimal(10, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  cliente Cliente           @relation(fields: [clienteId], references: [id])
  modelo  ModeloCertificado @relation(fields: [modeloId], references: [id])
  pedido  Pedido?           @relation(fields: [pedidoId], references: [id])

  emailsEnviados    EmailLog[]
  historicoContatos HistoricoContato[]

  certificadoAnteriorId String?      @unique
  certificadoAnterior   Certificado? @relation("RenovacaoCertificado", fields: [certificadoAnteriorId], references: [id])
  certificadoRenovacao  Certificado? @relation("RenovacaoCertificado")

  motivoNaoRenovacao String?
  naoRenovadoEm      DateTime?
  naoRenovadoPorId   String?
  naoRenovadoPor     Usuario? @relation("CertificadoNaoRenovadoPor", fields: [naoRenovadoPorId], references: [id])

  motivoRevogacao String?
  revogadoEm      DateTime?
  revogadoPorId   String?
  revogadoPor     Usuario? @relation("CertificadoRevogadoPor", fields: [revogadoPorId], references: [id])

  renovacaoManual RenovacaoManual?

  ocorrenciasQualidade OcorrenciaQualidade[]

  @@index([clienteId, modeloId, status])
  @@map("certificados")
}

// ─── RENOVAÇÕES MANUAIS (Controle de Vencimentos — origem fora da V&G) ────────

model RenovacaoManual {
  id        String   @id @default(cuid())
  clienteId String?

  nome     String
  cpfCnpj  String?
  telefone String?
  email    String?
  tipoPessoa TipoPessoa?

  modeloDescricao String?
  dataVencimento  DateTime
  observacoes     String? @db.Text

  origem OrigemRenovacaoManual @default(MANUAL)
  status StatusRenovacaoManual @default(PROSPECT)

  certificadoConvertidoId String?   @unique
  convertidoEm            DateTime?
  encerradoEm              DateTime?

  criadoPorId   String?
  responsavelId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente               Cliente?     @relation(fields: [clienteId], references: [id])
  certificadoConvertido Certificado? @relation(fields: [certificadoConvertidoId], references: [id])
  criadoPor             Usuario?     @relation("RenovacaoManualCriadoPor", fields: [criadoPorId], references: [id])
  responsavel           Usuario?     @relation("RenovacaoManualResponsavel", fields: [responsavelId], references: [id])

  @@index([cpfCnpj, status])
  @@index([status])
  @@map("renovacoes_manuais")
}

// ─── PEDIDOS DE VENDA ─────────────────────────────────────────────────────────

model Pedido {
  id               String       @id @default(cuid())
  numero           String       @unique
  clienteId        String
  parceiroId       String?
  usuarioId        String
  agr              String?      // ana.karolina | arlen | vinicius | laryssa
  status           StatusPedido @default(GERADO)
  valorTotal       Decimal      @db.Decimal(10, 2)
  desconto         Decimal      @default(0) @db.Decimal(10, 2)
  valorFinal       Decimal      @db.Decimal(10, 2)
  formaPagamento       String?
  tipoAtendimento      String?      // presencial | videoconferencia
  numeroCompra         String?      // número do protocolo Safeweb (Hope)
  voucher              String?
  boletoUrl            String?
  boletoCodigo         String?
  boletoVencimento     DateTime?
  verificadoEm         DateTime?
  emitidoEm            DateTime?
  canceladoEm          DateTime?    // data/hora do cancelamento (detalhes em AuditLog)
  safewebCancelamentoPendente Boolean @default(false) // true se cancelamento local ocorreu sem confirmação da Safeweb
  observacoes          String?
  contabilidade        String?      // escritório de contabilidade / parceiro indicador
  codigoCobranca       String?      // código de cobrança (financeiro)
  atendimentoExterno   Boolean      @default(false)
  valorDeslocamento    Decimal?     @db.Decimal(10, 2)
  unidadeAtendimento   String?      // cidade / unidade do AGR
  safewebStatus        String?      // último evento recebido via webhook Safeweb
  safewebProtocolo     String?      // número do protocolo gerado na Safeweb
  hopeUrlDocumentos    String?      // link do Hope Portal para anexar documentação ao dossiê
  popupNotificacaoVisto Boolean     @default(false) // marca se o AGR já viu/fechou o popup automático de "Certificado Emitido"
  safewebSerieA3       String?                     // número de série do certificado A3 PF usado na emissão online
  ignorarReconciliacaoFinanceira Boolean @default(false) // true: cobrança feita fora do CertFlow, nunca deve gerar Lancamento automático
  ignorarMetricasVendas Boolean @default(false) // true: certificado real emitido mas a venda não foi feita pelo CertFlow — não contar em dashboards/relatórios de vendas
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  cliente      Cliente      @relation(fields: [clienteId], references: [id])
  parceiro     Parceiro?    @relation(fields: [parceiroId], references: [id])
  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  itens          ItemPedido[]
  certificados   Certificado[]
  lancamentos    Lancamento[]
  comissaoPedido ComissaoPedido?
  eventosWebhook EventoWebhook[]
  ocorrenciasQualidade OcorrenciaQualidade[]

  @@map("pedidos")
}

model ItemPedido {
  id        String  @id @default(cuid())
  pedidoId  String
  modeloId  String
  quantidade Int    @default(1)
  precoUnit Decimal @db.Decimal(10, 2)
  desconto  Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  pedido Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  modelo ModeloCertificado @relation(fields: [modeloId], references: [id])

  @@map("itens_pedido")
}

// ─── FINANCEIRO ───────────────────────────────────────────────────────────────

model CategoriaFinanceira {
  id        String        @id @default(cuid())
  nome      String
  tipo      TipoTransacao
  cor       String?
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())

  lancamentos Lancamento[]

  @@map("categorias_financeiras")
}

model Lancamento {
  id             String           @id @default(cuid())
  tipo           TipoLancamento
  descricao      String
  valor          Decimal          @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusLancamento @default(PENDENTE)
  categoriaId    String?
  pedidoId       String?
  parceiroId     String?
  comprovante      String?
  notaFiscal       String?
  boleto           String?    // linha digitável
  observacoes      String?
  referencia       String?
  tipoConta        String?
  centroCusto      String?
  formaPagamento   String?
  banco            String?
  interCobrancaId  String?    // nosso número Inter
  interCodigoSolicitacao String?  // ID interno da cobrança no Inter (necessário para consultar/baixar PDF)
  pixCopiaECola    String?    // Pix copia e cola
  bonificado       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  pedido    Pedido?              @relation(fields: [pedidoId], references: [id])
  parceiro  Parceiro?            @relation(fields: [parceiroId], references: [id])
  comissoesPedido ComissaoPedido[]

  @@map("lancamentos")
}

// ─── E-MAILS ──────────────────────────────────────────────────────────────────

model TemplateEmail {
  id        String              @id @default(cuid())
  tipo      TipoEmailAutomatico @unique
  assunto   String
  corpo     String              @db.Text
  ativo     Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  @@map("templates_email")
}

model EmailLog {
  id            String              @id @default(cuid())
  clienteId     String
  certificadoId String?
  tipo          TipoEmailAutomatico
  destinatario  String
  assunto       String
  status        StatusEmail         @default(PENDENTE)
  erro          String?
  enviadoEm     DateTime?
  agendadoPara  DateTime?
  entregueEm    DateTime?
  abertoEm      DateTime?
  clicadoEm     DateTime?
  motivoFalha   String?
  createdAt     DateTime            @default(now())

  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  certificado Certificado? @relation(fields: [certificadoId], references: [id])

  @@map("email_logs")
}

// ─── AUDITORIA ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  usuarioId  String?
  acao       String
  entidade   String
  entidadeId String?
  dados      Json?
  ip         String?
  createdAt  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("audit_logs")
}

// ─── EVENTOS WEBHOOK SAFEWEB ─────────────────────────────────────────────────

model EventoWebhook {
  id           String   @id @default(cuid())
  evento       String   // ex.: "emissao", "verificacao", "cancelamento"
  acao         String?  // ex.: "aprovado", "Reprovado"
  protocolo    String
  numeroPedido String?
  clienteNome  String?
  agr          String?
  statusAntes  String?
  statusDepois String?
  motivoRecusa String?
  lido         Boolean  @default(false)
  payload      Json?
  pedidoId     String?
  createdAt    DateTime @default(now())

  pedido Pedido? @relation(fields: [pedidoId], references: [id])

  @@index([lido])
  @@index([createdAt])
  @@map("eventos_webhook")
}

// ─── CONFIGURAÇÕES ────────────────────────────────────────────────────────────

model Configuracao {
  id    String @id @default(cuid())
  chave String @unique
  valor String @db.Text

  @@map("configuracoes")
}

// ─── NOTÍCIAS / COMUNICADOS ───────────────────────────────────────────────────

model Noticia {
  id        String   @id @default(cuid())
  titulo    String
  resumo    String?
  conteudo  String   @db.Text
  categoria String   @default("Avisos")
  publicada Boolean  @default(false)
  fixada    Boolean  @default(false)
  autorNome String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("noticias")
}

// ─── SST — SEGURANÇA E SAÚDE NO TRABALHO ─────────────────────────────────────

model SSTLead {
  id              String         @id @default(cuid())
  nome            String
  empresa         String?
  cnpj            String?
  telefone        String?
  email           String?
  funcionarios    Int?
  laudos          String?
  valorEstimado   Decimal?       @db.Decimal(10, 2)
  parcelas        Int?
  origem          String?
  etapa           String         @default("PROSPECCAO")
  observacoes     String?        @db.Text
  responsavelNome String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  historico       SSTHistorico[]

  @@map("sst_leads")
}

model SSTHistorico {
  id        String   @id @default(cuid())
  leadId    String
  lead      SSTLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  texto     String   @db.Text
  autorNome String?
  createdAt DateTime @default(now())

  @@map("sst_historico")
}

// ─── ORÇAMENTOS ───────────────────────────────────────────────────────────────

model Orcamento {
  id           String   @id @default(cuid())
  destinatario String
  itens        Json
  formas       String[]
  total        Decimal  @db.Decimal(10, 2)
  geradoPor    String?
  usuario      Usuario? @relation(fields: [geradoPor], references: [id])
  createdAt    DateTime @default(now())

  @@map("orcamentos")
}

// ─── CONTEÚDO SOCIAL ─────────────────────────────────────────────────────────

model PostSocial {
  id        String   @id @default(cuid())
  categoria String
  semana    Int
  diaSemana String   // SEGUNDA, QUARTA, SEXTA
  headline  String
  legenda   String   @db.Text
  hashtags  String
  status    String   @default("PENDENTE") // PENDENTE, APROVADO
  criadoEm  DateTime @default(now())

  @@map("posts_social")
}

// ─── ATIVIDADE DE SESSÃO ──────────────────────────────────────────────────────

model SessaoAtividade {
  id            String   @id @default(cuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  data          DateTime
  minutosAtivos Int      @default(0)

  @@unique([usuarioId, data])
  @@map("sessao_atividade")
}

// ─── PENDÊNCIAS DO PROJETO (backlog conversado via Telegram) ──────────────────

enum StatusPendenciaProjeto {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
}

model PendenciaProjeto {
  id          String                  @id @default(cuid())
  titulo      String
  descricao   String?                 @db.Text
  status      StatusPendenciaProjeto  @default(PENDENTE)
  origem      String?                 // ex.: 'telegram', 'sessao-claude'
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  concluidoEm DateTime?

  @@map("pendencias_projeto")
}

// ─── ROBÔ DE AUDITORIA INTERNA ────────────────────────────────────────────────
// Histórico persistido no banco (não em log de servidor) — decisão de
// 26/06/2026, depois do incidente em que os logs de aplicação foram perdidos
// a cada deploy e impediram o diagnóstico de um problema real.

enum TipoAuditoriaRobo {
  LEVE
  PROFUNDA
}

enum StatusAuditoriaRobo {
  OK
  ACHADOS_SEM_CORRECAO
  CORRIGIDO_AUTOMATICAMENTE
  BLOQUEADO_AGUARDANDO_APROVACAO
}

model AuditoriaRobo {
  id           String              @id @default(cuid())
  tipo         TipoAuditoriaRobo
  status       StatusAuditoriaRobo
  achados      Json?
  correcoes    Json?
  // Diagnóstico de IA por achado investigado — [{ chaveDedup, categoria, texto, deCache }].
  // Adicionado 15/07/2026 (Robô Diagnosticador), ver src/lib/robo/diagnostico/.
  diagnosticos Json?
  duracaoMs    Int?
  createdAt    DateTime            @default(now())

  @@map("auditoria_robo")
}

// ─── GESTÃO DE PERFORMANCE DA EQUIPE (ICF) ────────────────────────────────────
// Módulo criado 15/07/2026 a pedido do Vinicius: dashboard "vivo" estilo TV de
// escritório, índice composto ICF = Produção 40% + Qualidade 40% + Renovação
// 20%. Toda regra de cálculo fica em src/lib/performance/*.ts — este schema só
// guarda os fatos brutos (metas, ocorrências, foco do dia, melhorias) e o
// resultado mensal já calculado (cache/histórico).

enum TipoOcorrenciaQualidade {
  ERRO_PEQUENO // -5 pontos
  RETRABALHO   // -10 pontos
  ERRO_GRAVE   // -30 pontos
  REVOGACAO    // zera a pontuação de qualidade do mês inteiro
}

enum StatusFoco {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
}

enum CategoriaMelhoria {
  ECONOMIA
  AUTOMACAO
  PROCESSO
  ATENDIMENTO
  MARKETING
}

enum StatusMelhoria {
  NOVA
  EM_ANALISE
  IMPLEMENTADA
}

// Meta mensal de produção — fonte única (substitui os valores hardcoded
// espalhados em widget-meta-vendas.tsx, dashboard-v2, meta-celebracao.tsx e
// painel-agr.tsx, que estavam desalinhados entre si: 300 vs 350).
model MetaPerformance {
  id           String   @id @default(cuid())
  mes          Int
  ano          Int
  metaProducao Int      @default(350)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([mes, ano])
  @@map("metas_performance")
}

// Evento imutável (mesmo padrão de AuditoriaRobo — só createdAt, sem
// updatedAt). Nomes/responsáveis só aparecem na tela administrativa; o
// dashboard e o Modo TV mostram só a pontuação agregada.
model OcorrenciaQualidade {
  id              String                  @id @default(cuid())
  data            DateTime                @default(now())
  tipo            TipoOcorrenciaQualidade
  descricao       String                  @db.Text
  observacao      String?                 @db.Text
  usuarioId       String?
  registradoPorId String?
  pedidoId        String?
  certificadoId   String?
  createdAt       DateTime                @default(now())

  usuario       Usuario?     @relation("OcorrenciaResponsavel", fields: [usuarioId], references: [id])
  registradoPor Usuario?     @relation("OcorrenciaRegistradoPor", fields: [registradoPorId], references: [id])
  pedido        Pedido?      @relation(fields: [pedidoId], references: [id])
  certificado   Certificado? @relation(fields: [certificadoId], references: [id])

  @@index([data])
  @@map("ocorrencias_qualidade")
}

// Um por dia — atualizado rapidamente durante a reunião diária de 10 minutos.
model FocoDoDia {
  id            String     @id @default(cuid())
  data          DateTime   @default(now()) @db.Date
  objetivo      String     @db.Text
  responsavelId String?
  prazo         DateTime?
  status        StatusFoco @default(PENDENTE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  responsavel Usuario? @relation(fields: [responsavelId], references: [id])

  @@map("foco_do_dia")
}

// Quadro de melhoria contínua — qualquer colaborador pode registrar uma ideia.
model MelhoriaContinua {
  id        String            @id @default(cuid())
  titulo    String
  descricao String            @db.Text
  categoria CategoriaMelhoria
  status    StatusMelhoria    @default(NOVA)
  autorId   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  autor Usuario? @relation(fields: [autorId], references: [id])

  @@map("melhorias_continuas")
}

// Foto mensal já calculada — evita recalcular agregações pesadas a cada
// carregamento do dashboard/TV, e serve como histórico permanente pra
// comparação entre meses (o mês corrente é sobrescrito diariamente pelo robô
// até fechar; meses passados ficam congelados).
model IndicadorMensal {
  id                     String   @id @default(cuid())
  mes                    Int
  ano                    Int
  producaoResultado      Int
  producaoMeta           Int
  producaoPercentual     Float
  qualidadePontuacao     Float
  qualidadeOcorrencias   Int
  renovacaoTaxaContato   Float
  renovacaoTaxaConversao Float
  renovacaoPercentual    Float
  icf                    Float
  calculadoEm            DateTime @default(now())

  @@unique([mes, ano])
  @@map("indicadores_mensais")
}

// Insights gerados diariamente pela IA a partir dos números já calculados
// (não é um chat — uma frase curta por vez, ver src/lib/performance/sugestoes-ia.ts).
model SugestaoIA {
  id        String   @id @default(cuid())
  data      DateTime @default(now()) @db.Date
  texto     String   @db.Text
  contexto  Json?
  createdAt DateTime @default(now())

  @@map("sugestoes_ia_performance")
}
