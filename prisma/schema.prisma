generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum TipoPessoa {
  PF
  PJ
}

enum TipoCertificado {
  A1
  A3
}

enum SuporteCertificado {
  TOKEN
  CARTAO
  NUVEM
  ARQUIVO
}

enum StatusCertificado {
  ATIVO
  VENCIDO
  CANCELADO
  RENOVADO
}

enum StatusPedido {
  GERADO
  VERIFICADO
  EMITIDO
  CANCELADO
}

enum TipoLancamento {
  RECEBER
  PAGAR
}

enum StatusLancamento {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum Role {
  ADMIN
  GERENTE
  OPERADOR
  FINANCEIRO
  VISUALIZADOR
}

enum StatusEmail {
  PENDENTE
  ENVIADO
  ERRO
}

enum TipoEmailAutomatico {
  VENCIMENTO_60
  VENCIMENTO_30
  VENCIMENTO_15
  VENCIMENTO_7
  POS_EMISSAO
  NUTRICAO_3M
  NUTRICAO_6M
  NUTRICAO_9M
}

// ─── USUÁRIOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id         String   @id @default(cuid())
  nome       String
  email      String   @unique
  senha      String
  role       Role     @default(OPERADOR)
  ativo      Boolean  @default(true)
  avatar     String?
  // Novos campos
  whatsapp   String?
  nomeAgrDs  String?   // Nome do AGR no Digisac
  unidade    String?   // Cidade/unidade (Piracaia, Bragança...)
  comissao   Decimal?  @db.Decimal(5, 2) // % comissão
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sessoes              Sessao[]
  auditoria            AuditLog[]
  pedidos              Pedido[]
  historicoContatos    HistoricoContato[]
  parceirosResponsavel Parceiro[]          @relation("ParceiroResponsavel")

  @@map("usuarios")
}

model Sessao {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sessoes")
}

// ─── CLIENTES ─────────────────────────────────────────────────────────────────

model Cliente {
  id             String     @id @default(cuid())
  tipoPessoa     TipoPessoa
  nome           String
  email          String?
  telefone       String?
  celular        String?
  cpf            String?    @unique
  cnpj           String?    @unique
  rg             String?
  dataNascimento DateTime?
  razaoSocial    String?
  nomeFantasia   String?
  responsavel    String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  observacoes    String?
  grupo          String?
  pisNis         String?
  ddd            String?
  ativo          Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  parceiro   Parceiro? @relation(fields: [parceiroId], references: [id])
  parceiroId String?

  certificados      Certificado[]
  pedidos           Pedido[]
  emails            EmailLog[]
  historicoContatos HistoricoContato[]

  @@map("clientes")
}

// ─── HISTÓRICO DE CONTATOS ────────────────────────────────────────────────────

model HistoricoContato {
  id             String    @id @default(cuid())
  clienteId      String
  certificadoId  String?
  observacao     String    @db.Text
  dataContato    DateTime  @default(now())
  proximoContato DateTime?
  usuarioId      String?
  createdAt      DateTime  @default(now())

  cliente     Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  certificado Certificado? @relation(fields: [certificadoId], references: [id])
  usuario     Usuario?     @relation(fields: [usuarioId], references: [id])

  @@map("historico_contatos")
}

// ─── PARCEIROS INDICADORES ────────────────────────────────────────────────────

model Parceiro {
  id          String     @id @default(cuid())
  tipoPessoa  TipoPessoa
  nome        String
  email       String?
  telefone    String?
  celular     String?
  cpf         String?    @unique
  cnpj        String?    @unique
  razaoSocial String?
  tipo        String
  banco       String?
  agencia     String?
  conta       String?
  tipoConta   String?
  chavePix    String?
  observacoes          String?
  ativo                Boolean    @default(true)
  // Campos extras
  nomeFantasia         String?
  nivel                String?
  tipoParceria         String?
  renovacoes           String?
  responsavelId        String?
  contadorResponsavel  String?
  pessoaContato        String?
  emailAlternativo     String?
  telefone2            String?
  informacoesEnvio     String?    @db.Text
  tipoComissao         String?
  diaPagamento         Int?
  loginParceiro        String?    @unique
  senhaParceiro        String?
  statusPainel         Boolean    @default(false)
  permissoesPainel     Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  responsavel      Usuario?          @relation("ParceiroResponsavel", fields: [responsavelId], references: [id])
  clientes         Cliente[]
  comissoes        Comissao[]
  pedidos          Pedido[]
  lancamentos      Lancamento[]
  contatosParceiro ContatoParceiro[]

  @@map("parceiros")
}

model ContatoParceiro {
  id             String    @id @default(cuid())
  parceiroId     String
  nome           String
  cpf            String?
  cargo          String?
  dataNascimento DateTime?
  telefone       String?
  email          String?
  createdAt      DateTime  @default(now())

  parceiro Parceiro @relation(fields: [parceiroId], references: [id], onDelete: Cascade)

  @@map("contatos_parceiro")
}

model Comissao {
  id         String   @id @default(cuid())
  parceiroId String
  modeloId   String
  percentual   Decimal?  @db.Decimal(5, 2)
  valorFixo    Decimal?  @db.Decimal(10, 2)
  valorCusto   Decimal?  @db.Decimal(10, 2)
  valorCliente Decimal?  @db.Decimal(10, 2)
  ativo        Boolean   @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parceiro Parceiro          @relation(fields: [parceiroId], references: [id])
  modelo   ModeloCertificado @relation(fields: [modeloId], references: [id])

  @@unique([parceiroId, modeloId])
  @@map("comissoes")
}

// ─── MODELOS DE CERTIFICADO ───────────────────────────────────────────────────

model ModeloCertificado {
  id              String             @id @default(cuid())
  nome            String
  descricao       String?
  tipoPessoa      TipoPessoa
  tipoCertificado TipoCertificado
  suporte         SuporteCertificado
  validadeMeses   Int                @default(12)
  preco           Decimal            @db.Decimal(10, 2)
  codigoSafeweb   String?
  ativo           Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  certificados Certificado[]
  comissoes    Comissao[]
  itensPedido  ItemPedido[]

  @@map("modelos_certificado")
}

// ─── CERTIFICADOS ─────────────────────────────────────────────────────────────

model Certificado {
  id             String            @id @default(cuid())
  clienteId      String
  modeloId       String
  pedidoId       String?
  numeroSerie    String?
  dataEmissao    DateTime
  dataVencimento DateTime
  status         StatusCertificado @default(ATIVO)
  safewebId      String?
  observacoes    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  cliente Cliente           @relation(fields: [clienteId], references: [id])
  modelo  ModeloCertificado @relation(fields: [modeloId], references: [id])
  pedido  Pedido?           @relation(fields: [pedidoId], references: [id])

  emailsEnviados    EmailLog[]
  historicoContatos HistoricoContato[]

  @@map("certificados")
}

// ─── PEDIDOS DE VENDA ─────────────────────────────────────────────────────────

model Pedido {
  id               String       @id @default(cuid())
  numero           String       @unique
  clienteId        String
  parceiroId       String?
  usuarioId        String
  agr              String?      // ana.karolina | arlen | vinicius | laryssa
  status           StatusPedido @default(GERADO)
  valorTotal       Decimal      @db.Decimal(10, 2)
  desconto         Decimal      @default(0) @db.Decimal(10, 2)
  valorFinal       Decimal      @db.Decimal(10, 2)
  formaPagamento       String?
  tipoAtendimento      String?      // presencial | videoconferencia
  numeroCompra         String?      // número do protocolo Safeweb (Hope)
  voucher              String?
  boletoUrl            String?
  boletoCodigo         String?
  boletoVencimento     DateTime?
  verificadoEm         DateTime?
  emitidoEm            DateTime?
  observacoes          String?
  contabilidade        String?      // escritório de contabilidade / parceiro indicador
  codigoCobranca       String?      // código de cobrança (financeiro)
  atendimentoExterno   Boolean      @default(false)
  valorDeslocamento    Decimal?     @db.Decimal(10, 2)
  unidadeAtendimento   String?      // cidade / unidade do AGR
  safewebStatus        String?      // último evento recebido via webhook Safeweb
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  cliente      Cliente      @relation(fields: [clienteId], references: [id])
  parceiro     Parceiro?    @relation(fields: [parceiroId], references: [id])
  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  itens        ItemPedido[]
  certificados Certificado[]
  lancamentos  Lancamento[]

  @@map("pedidos")
}

model ItemPedido {
  id        String  @id @default(cuid())
  pedidoId  String
  modeloId  String
  quantidade Int    @default(1)
  precoUnit Decimal @db.Decimal(10, 2)
  desconto  Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  pedido Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  modelo ModeloCertificado @relation(fields: [modeloId], references: [id])

  @@map("itens_pedido")
}

// ─── FINANCEIRO ───────────────────────────────────────────────────────────────

model CategoriaFinanceira {
  id        String        @id @default(cuid())
  nome      String
  tipo      TipoTransacao
  cor       String?
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())

  lancamentos Lancamento[]

  @@map("categorias_financeiras")
}

model Lancamento {
  id             String           @id @default(cuid())
  tipo           TipoLancamento
  descricao      String
  valor          Decimal          @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusLancamento @default(PENDENTE)
  categoriaId    String?
  pedidoId       String?
  parceiroId     String?
  comprovante      String?
  notaFiscal       String?
  boleto           String?    // linha digitável
  observacoes      String?
  referencia       String?
  tipoConta        String?
  centroCusto      String?
  formaPagamento   String?
  banco            String?
  interCobrancaId  String?    // nosso número Inter
  pixCopiaECola    String?    // Pix copia e cola
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  pedido    Pedido?              @relation(fields: [pedidoId], references: [id])
  parceiro  Parceiro?            @relation(fields: [parceiroId], references: [id])

  @@map("lancamentos")
}

// ─── E-MAILS ──────────────────────────────────────────────────────────────────

model TemplateEmail {
  id        String              @id @default(cuid())
  tipo      TipoEmailAutomatico @unique
  assunto   String
  corpo     String              @db.Text
  ativo     Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  @@map("templates_email")
}

model EmailLog {
  id            String              @id @default(cuid())
  clienteId     String
  certificadoId String?
  tipo          TipoEmailAutomatico
  destinatario  String
  assunto       String
  status        StatusEmail         @default(PENDENTE)
  erro          String?
  enviadoEm     DateTime?
  agendadoPara  DateTime?
  createdAt     DateTime            @default(now())

  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  certificado Certificado? @relation(fields: [certificadoId], references: [id])

  @@map("email_logs")
}

// ─── AUDITORIA ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  usuarioId  String?
  acao       String
  entidade   String
  entidadeId String?
  dados      Json?
  ip         String?
  createdAt  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("audit_logs")
}

// ─── CONFIGURAÇÕES ────────────────────────────────────────────────────────────

model Configuracao {
  id    String @id @default(cuid())
  chave String @unique
  valor String @db.Text

  @@map("configuracoes")
}

// ─── NOTÍCIAS / COMUNICADOS ───────────────────────────────────────────────────

model Noticia {
  id        String   @id @default(cuid())
  titulo    String
  resumo    String?
  conteudo  String   @db.Text
  categoria String   @default("Avisos")
  publicada Boolean  @default(false)
  fixada    Boolean  @default(false)
  autorNome String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("noticias")
}

// ─── SST — SEGURANÇA E SAÚDE NO TRABALHO ─────────────────────────────────────

model SSTLead {
  id              String         @id @default(cuid())
  nome            String
  empresa         String?
  cnpj            String?
  telefone        String?
  email           String?
  funcionarios    Int?
  laudos          String?
  valorEstimado   Decimal?       @db.Decimal(10, 2)
  parcelas        Int?
  origem          String?
  etapa           String         @default("PROSPECCAO")
  observacoes     String?        @db.Text
  responsavelNome String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  historico       SSTHistorico[]

  @@map("sst_leads")
}

model SSTHistorico {
  id        String   @id @default(cuid())
  leadId    String
  lead      SSTLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  texto     String   @db.Text
  autorNome String?
  createdAt DateTime @default(now())

  @@map("sst_historico")
}
